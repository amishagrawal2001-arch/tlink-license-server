{
  "name": "tlink-license-server",
  "version": "1.0.0",
  "description": "Centralized License Management Server for Tlink Products",
  "main": "src/index.js",
  "bin": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node scripts/seed.js",
    "test": "jest --verbose",
    "package": "pkg . --output dist/tlink-license-server --compress GZip",
    "package:mac": "pkg . --target node18-macos-arm64,node18-macos-x64 --output dist/tlink-license-server-macos --compress GZip",
    "package:win": "pkg . --target node18-win-x64 --output dist/tlink-license-server-win.exe --compress GZip",
    "package:linux": "pkg . --target node18-linux-x64 --output dist/tlink-license-server-linux --compress GZip",
    "package:all": "npm run package:mac && npm run package:win && npm run package:linux"
  },
  "pkg": {
    "assets": ["admin/**/*", "docs/**/*"],
    "targets": ["node18-macos-arm64", "node18-win-x64", "node18-linux-x64"],
    "outputPath": "dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "author": "Tlink Technologies",
  "license": "SEE LICENSE IN LICENSE"
}
